+static int fm25s02b_ecc_get_status(struct spinand_device *spinand,
+				     u8 status)
+{
+	switch (status & FM25S02B_STATUS_ECC_MASK) {
+	case FM25S02B_STATUS_ECC_NO_BITFLIPS:
+		return 0;
+
+	case FM25S02B_STATUS_ECC_UNCOR_ERROR:
+		return -EBADMSG;
+
+	case FM25S02B_STATUS_ECC_1_3_BITFLIPS:
+		return 3;
+
+	case FM25S02B_STATUS_ECC_4_BITFLIPS:
+		return 4;
+
+	case FM25S02B_STATUS_ECC_5_BITFLIPS:
+		return 5;
+
+	case FM25S02B_STATUS_ECC_6_BITFLIPS:
+		return 6;
+
+	case FM25S02B_STATUS_ECC_7_BITFLIPS:
+		return 7;
+
+	case FM25S02B_STATUS_ECC_8_BITFLIPS:
+		return -EBADMSG;
+	default:
+		return -EINVAL;
+	}
+}
+
+static int fm25s02b_ooblayout_ecc(struct mtd_info *mtd, int section,
+				    struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 64;
+	region->length = 64;
+
+	return 0;
+}
+
+static int fm25s02b_ooblayout_free(struct mtd_info *mtd, int section,
+				     struct mtd_oob_region *region)
+{
+	if (section > 3)
+		return -ERANGE;
+
+	if (section == 0) {
+		region->offset = 2;
+		region->length = 14;
+	} else {
+		region->offset = 16 * section;
+		region->length = 16;
+	}
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops fm25s02b_ooblayout = {
+	.ecc = fm25s02b_ooblayout_ecc,
+	.free = fm25s02b_ooblayout_free,
+};
+
