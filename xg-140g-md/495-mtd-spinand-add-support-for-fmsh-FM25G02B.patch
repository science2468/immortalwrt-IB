+	case FM25G02B_STATUS_ECC_6_BITFLIPS:
+		return 6;
+	case FM25G02B_STATUS_ECC_7_BITFLIPS:
+		return 7;
+	case FM25G02B_STATUS_ECC_8_BITFLIPS:
+		return 8;
+	case FM25G02B_STATUS_ECC_UNCOR_ERROR:
+		return -EBADMSG;
+	default:
+		return -EINVAL;
+	}
