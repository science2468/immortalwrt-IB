+#define STATUS_FMSH_ECC_MASK		(7 << 4)
+#define STATUS_FMSH_ECC_NONE		(0 << 4)
+#define STATUS_FMSH_ECC_1BIT		(1 << 4)
+#define STATUS_FMSH_ECC_2BIT		(2 << 4)
+#define STATUS_FMSH_ECC_3BIT		(3 << 4)
+#define STATUS_FMSH_ECC_4BIT		(4 << 4)
+#define STATUS_FMSH_ECC_5BIT		(5 << 4)
+#define STATUS_FMSH_ECC_6BIT		(6 << 4)
+#define STATUS_FMSH_ECC_7BIT		(7 << 4)
+#define STATUS_FMSH_ECC_UNCORRECTABLE	(7 << 4)
+
+static int fm25g02b_ooblayout_ecc(struct mtd_info *mtd, int section,
+				  struct mtd_oob_region *region)
+{
+	if (section > 8)
+		return -ERANGE;
+
+	region->offset = 64 + (8 * section);
+	region->length = 8;
+
+	return 0;
+}
+
+static int fm25g02b_ooblayout_free(struct mtd_info *mtd, int section,
+				   struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 2;
+	region->length = 62;
+
+	return 0;
+}
+
+static int fm25g02b_ecc_get_status(struct spinand_device *spinand, u8 status)
+{
+	u8 ecc_bits = (status & STATUS_FMSH_ECC_MASK) >> 4;
+
+	switch (ecc_bits) {
+	case 0x00:
+		return 0;
+	case 0x01:
+		return 1;
+	case 0x02:
+		return 2;
+	case 0x03:
+		return 3;
+	case 0x04:
+		return 4;
+	case 0x05:
+		return 5;
+	case 0x06:
+		return 6;
+	case 0x07:
+		return -EBADMSG;
+	default:
+		break;
+	}
+	return -EINVAL;
+}
+
